{
  "name": "garmenthub",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "backend:dev": "npm run dev -w packages/backend",
    "backend:build": "npm run build -w packages/backend",
    "frontend:dev": "npm run dev -w packages/frontend",
    "frontend:build": "npm run build -w packages/frontend",
    "db:migrate": "npm run db:migrate -w packages/backend",
    "db:seed": "npm run db:seed -w packages/backend",
    "db:generate": "npm run db:generate -w packages/backend"
  },
  "devDependencies": {
    "prisma": "^7.8.0"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0"
  }
}
