DATABASE_URL="postgresql://postgres:postgres@localhost:5432/garmenthub?schema=public"
JWT_SECRET="super-secret-jwt-key-change-in-production"
PORT=4000

# Comma-separated browser origins allowed to call this API (required when the UI is on another host).
# When this list is non-empty, http://localhost:<any port> and http://127.0.0.1:<any port> are also allowed
# (Flutter web uses a random port each run; you do not need to list each one).
# Production (UI on garmenthub.in, API on service.garmenthub.in):
# CORS_ORIGINS="https://garmenthub.in,https://www.garmenthub.in"
# Local UI hitting local API directly (VITE_API_ORIGIN=http://localhost:4000):
# CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
# Flutter web on another machine (LAN IP in the browser bar) — add that origin explicitly; only localhost/127 are auto-allowed.
# CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:8080,http://YOUR_SERVER_IP:8080"
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# Multipart product image uploads (Multer). Your reverse proxy (e.g. nginx) must allow a body at least this large.
# MAX_UPLOAD_FILE_MB=20
# MAX_UPLOAD_FILES_PER_REQUEST=20
