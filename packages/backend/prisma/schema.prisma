generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  VENDOR
  ADMIN
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PARTIALLY_ACCEPTED
  REJECTED
  CONFIRMED
  CANCELLED
}

enum ItemStatus {
  PENDING
  ACCEPTED
  REJECTED
  ALTERED
  CONFIRMED
}

model User {
  id           String   @id @default(cuid())
  phone        String   @unique
  name         String   @default("")
  role         Role     @default(CUSTOMER)
  businessName String?
  address      String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  products                 Product[]
  brands                   Brand[]
  orders                   Order[]
  orderItems               OrderItem[]
  notifications            Notification[]
  vendorCategoryAttributes VendorCategoryAttribute[]

  @@map("users")
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products          Product[]
  attributes        CategoryAttribute[]
  vendorAttributes  VendorCategoryAttribute[]

  @@map("categories")
}

model CategoryAttribute {
  id         String   @id @default(cuid())
  categoryId String
  name       String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, name])
  @@index([categoryId])
  @@map("category_attributes")
}

model VendorCategoryAttribute {
  id         String   @id @default(cuid())
  vendorId   String
  categoryId String
  name       String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  vendor   User     @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([vendorId, categoryId, name])
  @@index([vendorId])
  @@index([categoryId])
  @@map("vendor_category_attributes")
}

model Brand {
  id        String   @id @default(cuid())
  vendorId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor   User      @relation(fields: [vendorId], references: [id])
  products Product[]

  @@unique([vendorId, name])
  @@index([vendorId])
  @@map("brands")
}

model Product {
  id              String        @id @default(cuid())
  vendorId        String
  brandId         String
  name            String
  images          String[]
  categoryId      String
  pattern         String        @default("")
  fabric          String        @default("")
  color           String        @default("")
  attributeValues Json          @default("{}")
  price           Float?
  moq             Int           @default(1)
  status          ProductStatus @default(ACTIVE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  vendor     User        @relation(fields: [vendorId], references: [id])
  brand      Brand       @relation(fields: [brandId], references: [id])
  category   Category    @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]

  @@index([vendorId])
  @@index([brandId])
  @@index([categoryId])
  @@index([status])
  @@map("products")
}

model Order {
  id         String      @id @default(cuid())
  customerId String
  status     OrderStatus @default(PENDING)
  note       String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  customer User        @relation(fields: [customerId], references: [id])
  items    OrderItem[]

  @@index([customerId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id           String     @id @default(cuid())
  orderId      String
  productId    String
  vendorId     String
  requestedQty Int
  acceptedQty  Int?
  status       ItemStatus @default(PENDING)
  vendorNote   String?
  respondedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  vendor  User    @relation(fields: [vendorId], references: [id])

  @@index([orderId])
  @@index([vendorId])
  @@index([status])
  @@map("order_items")
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  body        String
  referenceId String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model OtpStore {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
  @@map("otp_store")
}
