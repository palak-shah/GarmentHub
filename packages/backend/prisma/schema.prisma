generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  VENDOR
  TRADER
  ADMIN
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PARTIALLY_ACCEPTED
  REJECTED
  CONFIRMED
  CANCELLED
}

enum ItemStatus {
  PENDING
  ACCEPTED
  REJECTED
  ALTERED
  CONFIRMED
}

model User {
  id           String   @id @default(cuid())
  phone        String   @unique
  name         String   @default("")
  role         Role     @default(CUSTOMER)
  businessName String?
  address      String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  products                 Product[]       @relation("vendorProducts")
  tradedProducts           Product[]       @relation("traderProducts")
  brands                   Brand[]
  orders                   Order[]
  orderItems               OrderItem[]
  notifications            Notification[]
  vendorCategoryAttributes VendorCategoryAttribute[]
  savedProducts            SavedProduct[]
  followers                Connection[]    @relation("following")
  following                Connection[]    @relation("followers")
  traderOrders             Order[]         @relation("traderOrders")
  curatedSharesSent        CuratedShare[]  @relation("curatedSharesSent")
  curatedSharesReceived    CuratedShareRecipient[] @relation("curatedSharesReceived")
  productStates            UserProductState[]
  inviteCode               String?         @unique
  traderCustomerGroups     CustomerGroup[] @relation("TraderCustomerGroups")
  customerGroupMemberships CustomerGroupMember[]

  @@map("users")
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products          Product[]
  attributes        CategoryAttribute[]
  vendorAttributes  VendorCategoryAttribute[]

  @@map("categories")
}

model CategoryAttribute {
  id         String   @id @default(cuid())
  categoryId String
  name       String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, name])
  @@index([categoryId])
  @@map("category_attributes")
}

model VendorCategoryAttribute {
  id         String   @id @default(cuid())
  vendorId   String
  categoryId String
  name       String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  vendor   User     @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([vendorId, categoryId, name])
  @@index([vendorId])
  @@index([categoryId])
  @@map("vendor_category_attributes")
}

model Brand {
  id        String   @id @default(cuid())
  vendorId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor   User      @relation(fields: [vendorId], references: [id])
  products Product[]

  @@unique([vendorId, name])
  @@index([vendorId])
  @@map("brands")
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  createdAt DateTime @default(now())

  product           Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  curatedShareLines CuratedShareProduct[]
  orderItems        OrderItem[]

  @@unique([productId, url])
  @@index([productId, createdAt(sort: Desc)])
  @@map("product_images")
}

model Product {
  id              String        @id @default(cuid())
  vendorId        String
  traderId        String?
  brandId         String
  name            String
  images          String[]
  categoryId      String
  pattern         String        @default("")
  fabric          String        @default("")
  color           String        @default("")
  attributeValues Json          @default("{}")
  price           Float?
  priceMax        Float?
  moq             Int           @default(1)
  status          ProductStatus @default(ACTIVE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  vendor        User           @relation("vendorProducts", fields: [vendorId], references: [id])
  trader        User?          @relation("traderProducts", fields: [traderId], references: [id])
  brand         Brand          @relation(fields: [brandId], references: [id])
  category      Category       @relation(fields: [categoryId], references: [id])
  orderItems          OrderItem[]
  savedProducts       SavedProduct[]
  curatedShareItems   CuratedShareProduct[]
  userProductStates   UserProductState[]
  imageAssets         ProductImage[]

  @@index([vendorId])
  @@index([traderId])
  @@index([brandId])
  @@index([categoryId])
  @@index([status])
  @@map("products")
}

enum OrderMode {
  DIRECT
  MANAGED
}

model Order {
  id                   String      @id @default(cuid())
  customerId           String
  traderId             String?
  orderMode            OrderMode   @default(DIRECT)
  status               OrderStatus @default(PENDING)
  note                 String?
  /** Customer-requested need-by instant: end of chosen calendar day in UTC (23:59:59.999). */
  customerNeedBy       DateTime?
  /** Managed orders: set when trader sends the order to vendors; until then vendors do not see line items. */
  releasedToVendorsAt  DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  customer User        @relation(fields: [customerId], references: [id])
  trader   User?       @relation("traderOrders", fields: [traderId], references: [id])
  items    OrderItem[]

  @@index([customerId])
  @@index([traderId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id                     String     @id @default(cuid())
  orderId                String
  productId              String
  vendorId               String
  requestedQty           Int
  acceptedQty            Int?
  status                 ItemStatus @default(PENDING)
  vendorNote             String?
  respondedAt            DateTime?
  offeredUnitPrice       Float?
  /** Trader's favored unit price (managed pre-vendor send, or direct while all lines PENDING). */
  traderTargetUnitPrice  Float?
  traderCounterUnitPrice Float?
  agreedUnitPrice        Float?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  vendor  User    @relation(fields: [vendorId], references: [id])
  /** Optional: which shared catalog photo this line refers to. */
  productImageId String?
  productImage   ProductImage? @relation(fields: [productImageId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([vendorId])
  @@index([status])
  @@index([productImageId])
  @@map("order_items")
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  body        String
  referenceId String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model OtpStore {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
  @@map("otp_store")
}

model Connection {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("followers", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("connections")
}

model SavedProduct {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@map("saved_products")
}

enum WorkflowState {
  UNSEEN
  SEEN
  SHARED
  ORDERED
  SKIPPED
}

model UserProductState {
  id        String        @id @default(cuid())
  userId    String
  productId String
  state     WorkflowState @default(UNSEEN)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId, state])
  @@index([productId])
  @@map("user_product_states")
}

model CustomerGroup {
  id        String   @id @default(cuid())
  traderId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trader  User                  @relation("TraderCustomerGroups", fields: [traderId], references: [id], onDelete: Cascade)
  members CustomerGroupMember[]

  @@index([traderId])
  @@map("customer_groups")
}

model CustomerGroupMember {
  id         String   @id @default(cuid())
  groupId    String
  customerId String
  createdAt  DateTime @default(now())

  group    CustomerGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  customer User          @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([groupId, customerId])
  @@index([customerId])
  @@map("customer_group_members")
}

model CuratedShare {
  id         String    @id @default(cuid())
  traderId   String
  note       String?
  orderMode  OrderMode @default(DIRECT)
  createdAt  DateTime  @default(now())

  trader     User                    @relation("curatedSharesSent", fields: [traderId], references: [id], onDelete: Cascade)
  products   CuratedShareProduct[]
  recipients CuratedShareRecipient[]

  @@index([traderId])
  @@map("curated_shares")
}

model CuratedShareProduct {
  id             String  @id @default(cuid())
  curatedShareId String
  productId      String
  productImageId String?
  /** Trader's favored unit price for this share line (buyer sees this when ordering from the share). */
  traderOfferUnitPrice Float?

  curatedShare CuratedShare @relation(fields: [curatedShareId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  productImage ProductImage? @relation(fields: [productImageId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@map("curated_share_products")
}

model CuratedShareRecipient {
  id             String  @id @default(cuid())
  curatedShareId String
  customerId     String
  isRead         Boolean @default(false)

  curatedShare CuratedShare @relation(fields: [curatedShareId], references: [id], onDelete: Cascade)
  customer     User         @relation("curatedSharesReceived", fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([curatedShareId, customerId])
  @@index([customerId, isRead])
  @@map("curated_share_recipients")
}
