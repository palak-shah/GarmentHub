# --- Production / staging (UI and API on different hosts) ---
# Build with these so the browser calls the API directly (no redirect, no same-origin /api).
# VITE_API_ORIGIN=https://service.garmenthub.in
# VITE_PUBLIC_API_ORIGIN=https://service.garmenthub.in

# --- Local dev: call local API without going through the Vite proxy ---
# Backend must allow Origin http://localhost:3000 (set CORS_ORIGINS in packages/backend/.env).
# VITE_API_ORIGIN=http://localhost:4000

# --- Local dev: optional override for what `vite` proxies `/api` and `/uploads` to ---
# Default is http://localhost:4000. Not a VITE_* var (only read by vite.config, never bundled).
# DEV_PROXY_TARGET=http://localhost:4000

# Vendor product photo uploads: how many files per multipart POST (1–20). Default 2 for strict nginx (1m body).
# After raising reverse-proxy `client_max_body_size`, try 10 or 20 for fewer round-trips.
# VITE_UPLOAD_IMAGE_CHUNK=2
